# Server Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/context_vault"

# Authentication
JWT_SECRET="your_strong_random_secret_at_least_32_chars"

# AI Provider
AI_PROVIDER=gemini
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL_PRIMARY="gemini-1.5-pro"
GEMINI_MODEL_FALLBACK="gemini-1.5-flash"

# Frontend
FRONTEND_URL="http://localhost:5173"
ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# GitHub App Integration
GITHUB_APP_ID="your_github_app_id"
GITHUB_APP_SLUG="your_github_app_slug"
GITHUB_PRIVATE_KEY_PATH="./secrets/github-app-private-key.pem"
GITHUB_CALLBACK_URL="http://localhost:3000/api/github/callback"
