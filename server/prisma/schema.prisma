generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  password             String
  createdAt            DateTime  @default(now())
  onboardingCompleted  Boolean   @default(false)
  onboardingCompletedAt DateTime?
  projects             Project[]
}

model Project {
  id               String            @id @default(uuid())
  name             String
  description      String?
  userId           String
  createdAt        DateTime          @default(now())
  contextSnapshots ContextSnapshot[]
  contextUpdates   ContextUpdate[]
  exports          Export[]
  smartExportCache SmartExportCache[]
  gitChangeImports GitChangeImport[]
  githubIntegrations GitHubIntegration[]
  user             User              @relation(fields: [userId], references: [id])
}

model GitHubIntegration {
  id                   String    @id @default(uuid())
  projectId            String    @unique
  userId               String
  repoOwner            String?
  repoName             String?
  repoFullName         String?
  repoUrl              String?
  defaultBranch        String?
  selectedBranch       String?
  installationId       String
  githubAccountId      String?
  githubAccountLogin    String?
  accessTokenEncrypted   String?
  permissionsSummary   String?
  isActive             Boolean   @default(true)
  connectedAt          DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  lastSyncedCommitSha  String?
  project              Project   @relation(fields: [projectId], references: [id])
}

model GitHubInstallState {
  state     String   @id
  projectId String
  userId    String
  expiresAt DateTime
}


model ContextSnapshot {
  id            String   @id @default(uuid())
  projectId     String
  versionNumber Int
  contextJson   Json
  createdAt     DateTime @default(now())
  project       Project  @relation(fields: [projectId], references: [id])
}

model ContextUpdate {
  id                  String   @id @default(uuid())
  projectId           String
  rawInput            String
  extractedUpdateJson Json
  createdAt           DateTime @default(now())
  project             Project  @relation(fields: [projectId], references: [id])
}

model Export {
  id        String   @id @default(uuid())
  projectId String
  target    String
  content   String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id])
}

model SmartExportCache {
  id                   String   @id @default(uuid())
  projectId            String
  versionNumber        Int
  normalizedTask       String
  originalTask         String
  targetPlatform       String
  exportText           String
  characterCount       Int
  estimatedTokens      Int
  fullEstimatedTokens  Int
  estimatedSavingsPercent Float?
  relevanceMode        String
  aiMetadata           Json
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  project              Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, versionNumber, normalizedTask, targetPlatform])
}

model GitChangeImport {
  id                    String   @id @default(uuid())
  projectId             String
  userId                String
  title                 String?
  changeType            String
  branch                String?
  baseBranch            String?
  sanitizedInputPreview String?
  rawInputHash          String?
  suggestedUpdateJson   Json?
  redactionCount        Int      @default(0)
  status                String   // analyzed, applied, cancelled, failed
  createdVersionId      String?
  errorMessage          String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  appliedAt             DateTime?
  preprocessingMetadata Json?
  project               Project  @relation(fields: [projectId], references: [id])
}
